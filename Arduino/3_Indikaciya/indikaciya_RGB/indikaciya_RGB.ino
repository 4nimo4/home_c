//---------------------------------------------------------------------------------------------
//  Голубой
//---------------------------------------------------------------------------------------------
void light_blue(){
  analogWrite(LED_RED_USER, 0);
  int b=60;
  int g=255;
  for (int i = 0; i<SHIM; i++) {
    if(i<b){
      analogWrite(LED_BLUE_USER, i);
    }
    if(i<g){
      analogWrite(LED_GREEN_USER, i);
    }
    delay (10);
  }
  delay(DELAY);
  for (int i=SHIM; i>=0; i--)
  {
    if(i<b){
      analogWrite(LED_BLUE_USER, i);
    }
    if(i<g){
      analogWrite(LED_GREEN_USER, i);
    }
    delay(10);
  }
}
