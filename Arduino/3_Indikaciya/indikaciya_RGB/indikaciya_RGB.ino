#define LED_BLUE_USER   11            // внешний синий светодиод
#define LED_RED_USER    10            // внешний красный светодиод
#define LED_GREEN_USER   9            // внешний зеленый светодиод

#define DELAY         10              //задержка для светодиодов
#define SHIM         255              //задержка для светодиодов
#define MOVE_TIMEOUT 5000            // время ожидания ввода равное 10 секундам


//---------------------------------------------------------------------------------------------
// Прототипы функций
//---------------------------------------------------------------------------------------------
void blue();
void red();
void green();
void light_blue();
void yellow();
void orange();
void violet();

//---------------------------------------------------------------------------------------------
// Глобальные переменныке и объекты
//---------------------------------------------------------------------------------------------
bool lastBtnState = HIGH;           // Предыдущее состояние кнопки (HIGH = не нажата при INPUT_PULLUP)
bool btnState = 0;                  //Состояние кнопки текущее
int lastPos = 0;                    // Предыдущее положение потенциометра (для отслеживания изменения)
unsigned long lastMoveTime = 0;      // время последнего начала отсчета до выхода из режима настройки

//---------------------------------------------------------------------------------------------
// Настройка платы
//---------------------------------------------------------------------------------------------
void setup() {  
  pinMode(LED_BLUE_USER, OUTPUT);    
  pinMode(LED_RED_USER, OUTPUT); 
  pinMode(LED_GREEN_USER, OUTPUT); 
  Serial.begin(9600);               // Запускаем последовательный порт на скорости 9600 бод
}

//---------------------------------------------------------------------------------------------
// Главный цикл
//---------------------------------------------------------------------------------------------
void loop() {
  blue();
  //---------------------------------------------------------------------------------------------
  //delay(DELAY);                               // Пауза 30 мс перед новым циклом
  //---------------------------------------------------------------------------------------------
