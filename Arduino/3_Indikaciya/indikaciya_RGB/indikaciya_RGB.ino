  //---------------------------------------------------------------------------------------------
  orange();
  //---------------------------------------------------------------------------------------------
  //delay(DELAY);                               // Пауза 30 мс перед новым циклом
  //---------------------------------------------------------------------------------------------
  violet();
  //---------------------------------------------------------------------------------------------
  //delay(DELAY);                               // Пауза 30 мс перед новым циклом

}

//---------------------------------------------------------------------------------------------
//  Синий
//---------------------------------------------------------------------------------------------
void blue(){
  for (int i = 0; i<SHIM; i++) {
    analogWrite(LED_BLUE_USER, i);
    delay (10);
  }
  delay(DELAY);
  for (int i=SHIM; i>=0; i--)
  {
    analogWrite(LED_BLUE_USER, i);
    delay(10);
  }
}
//---------------------------------------------------------------------------------------------
//  Красный
//---------------------------------------------------------------------------------------------
void red(){
  for (int i = 0; i<SHIM; i++) {
    analogWrite(LED_RED_USER, i);
