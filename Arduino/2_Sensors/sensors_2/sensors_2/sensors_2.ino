//---------------------------------------------------------------------------------------------
// Экспоненциальный фильтр
//---------------------------------------------------------------------------------------------
/*каждый новый отсчёт чуть-чуть подмешивается к предыдущему результату.
Гладкая кривая, меньше шума, но с небольшим запаздыванием.*/

// Экспоненциальное сглаживание, результат 0..10
float expoFilterA0(float alpha) {
  int raw = analogRead(A0);                 // 0..1023
  int val = map(raw, 0, 910, 0, 10);       // 0..10
  val = constrain(val, 0, 10);

  if (valExpo < 0) {        // первый вызов
    valExpo = val;
  } else {
    valExpo = valExpo + (val - valExpo) * alpha;
  }
  return valExpo;
}

//---------------------------------------------------------------------------------------------
// Скользящее среднее по окну WINDOW
//---------------------------------------------------------------------------------------------
// Скользящее среднее по окну WINDOW, результат 0..10
int movingAverageA0() {
  int raw = analogRead(A0);                 // 0..1023
  int val = map(raw, 0, 910, 0, 10);       // 0..10
  val = constrain(val, 0, 10);

  // вычитаем старое значение из суммы
  sumWin -= bufWin[idxWin];
  // записываем новое
  bufWin[idxWin] = val;
  // добавляем к сумме
  sumWin += val;

  idxWin++;
  if (idxWin >= WINDOW) {
    idxWin = 0;
    windowFilled = true;
  }

  int n = windowFilled ? WINDOW : idxWin;   // сколько реально значений в буфере
  if (n == 0) return val;                  // защита на первом шаге

  return (int)(sumWin / n);
}
//---------------------------------------------------------------------------------------------
// Вывод на индикацию
//---------------------------------------------------------------------------------------------
 void printAllFilters() 
 {
    //---------------------------------------------------------------------------------------------
    if(filtr == 1)
    { //Фильтрация отключена - выводим сырые значения
      int raw = analogRead(A0);                 // 0..1023
      int pos = map(raw, 0, 910, 0, 10);       // 0..10
      pos = constrain(pos, 0, 10);

      if (pos != lastPos) 
      {
        Serial.print("  без фильтрации =");
        Serial.println(pos);
        if (pos > lastPos) 
        {
          for(int i=ADR_LED_MIN+lastPos, y=i+pos-lastPos; i<y; i++)
            {   
              digitalWrite(i, HIGH);
              delay(DELAY);
            }
        }
        else
        {
          for(int i=ADR_LED_MIN+lastPos-1, y=i-(lastPos-pos); i>y; i--)
          {  
            digitalWrite(i, LOW);
            delay(DELAY);
          }
        }
        lastPos = pos;                    // обновляем
      }
    }

    //---------------------------------------------------------------------------------------------
    else if(filtr == 2)
    { //Фильтрация экспоненциальное сглаживание
      float expo = expoFilterA0(koeff);
      int pos = (int)round(expo);
      if (pos != lastPos) 
      {
        Serial.print("  экспоненциальное сглаживание =");
        Serial.println(pos);
        if (pos > lastPos) 
        {
          for(int i=ADR_LED_MIN+lastPos, y=i+pos-lastPos; i<y; i++)
            {   
              digitalWrite(i, HIGH);
              delay(DELAY);
            }
        }
        else
        {
          for(int i=ADR_LED_MIN+lastPos-1, y=i-(lastPos-pos); i>y; i--)
          {  
            digitalWrite(i, LOW);
            delay(DELAY);
          }
        }
        lastPos = pos;                    // обновляем
      }
    }

    //---------------------------------------------------------------------------------------------
    else if(filtr == 3)
    { //Фильтрация Скользящее среднее по окну WINDOW
      int maWindow = movingAverageA0();
      int pos = maWindow;
      if (pos != lastPos) 
      {
        Serial.print("  скользящее среднее по окну WINDOW =");

        Serial.println(pos);
        if (pos > lastPos) 
        {
          for(int i=ADR_LED_MIN+lastPos, y=i+pos-lastPos; i<y; i++)
            {   
              digitalWrite(i, HIGH);
              delay(DELAY);
            }
        }
        else
        {
          for(int i=ADR_LED_MIN+lastPos-1, y=i-(lastPos-pos); i>y; i--)
          {  
            digitalWrite(i, LOW);
            delay(DELAY);
          }
        }
        lastPos = pos;                    // обновляем
      }
    }    
  }
  //---------------------------------------------------------------------------------------------

  
  
 

